# -------------------------------------------------
# Data files (never commit raw or processed data)
# -------------------------------------------------
data/raw/
data/processed/

# -------------------------------------------------
# Python bytecode & cache
# -------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# -------------------------------------------------
# Jupyter Notebook checkpoints
# -------------------------------------------------
.ipynb_checkpoints/

# -------------------------------------------------
# Virtual environments
# -------------------------------------------------
venv/
.venv/
.env/

# -------------------------------------------------
# Model artifacts (saved models, checkpoints)
# -------------------------------------------------
models/
checkpoints/
*.joblib
*.pkl

# -------------------------------------------------
# Logs & experiment outputs
# -------------------------------------------------
logs/
*.log

# -------------------------------------------------
# OS-specific files
# -------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------
# IDE / editor settings
# -------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------------------------------
# Temporary files
# -------------------------------------------------
*.tmp
*.temp
